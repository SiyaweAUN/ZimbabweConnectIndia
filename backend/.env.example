# =============================================
# ZimbabweConnectIndia Backend Environment
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/zimbabwe_connect_india
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/zimbabwe_connect_india

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin Registration Secret (used to create admin accounts)
ADMIN_SECRET=your_admin_registration_secret_key

# Email (Nodemailer - Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=ZimbabweConnectIndia <noreply@zimbabweconnectindia.com>

# WhatsApp Contact Number
WHATSAPP_NUMBER=+263771234567

# File Upload (Max size in MB)
MAX_FILE_SIZE=5
